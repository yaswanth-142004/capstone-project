OLLAMA_MODEL=gemma4:26b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_SERVICE_HOST=0.0.0.0
OLLAMA_SERVICE_PORT=8088
OLLAMA_SERVICE_TIMEOUT=180
OLLAMA_SERVICE_CORS_ORIGINS=*
MURIL_MODEL=google/muril-base-cased
MURIL_DEVICE=auto
MURIL_PROGRESS=true
CHROMA_DIR=./storage/chroma
CHROMA_COLLECTION=code_mixed_hate_memory
RAG_TOP_K=5
CONFIDENCE_THRESHOLD=0.68
HITL_QUEUE=./outputs/hitl_review_queue.csv
# Reflection loop
REFLECTION_ENABLED=true
MAX_REFLECTION_RETRIES=1
# Smart retrieval
MAX_RETRIEVAL_DISTANCE=1.2
# Auto-eval and auto-ingest
AUTO_INGEST_THRESHOLD=0.85
EVAL_BATCH_SIZE=50
LESSONS_PATH=./outputs/lessons.json
APP_LOG=./outputs/app.log
