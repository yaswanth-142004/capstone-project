LLM_PROVIDER=vllm

# Classifier-facing settings
VLLM_MODEL=google/gemma-2-9b-it
VLLM_BASE_URL=http://127.0.0.1:8090
VLLM_API_KEY=
VLLM_TIMEOUT_SECONDS=180

# Wrapper-service settings
VLLM_BACKEND_URL=http://127.0.0.1:8000
VLLM_SERVICE_HOST=0.0.0.0
VLLM_SERVICE_PORT=8090
VLLM_SERVICE_TIMEOUT=180
VLLM_SERVICE_CORS_ORIGINS=*

# Shared RAG settings
MURIL_MODEL=google/muril-base-cased
CHROMA_DIR=./storage/chroma
CHROMA_COLLECTION=code_mixed_hate_memory
RAG_TOP_K=5
CONFIDENCE_THRESHOLD=0.68
HITL_QUEUE=./outputs/hitl_review_queue.csv
APP_LOG=./outputs/app.log
